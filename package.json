{
  "name": "scraper-secpral-spishop",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "scrape": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=integration",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=e2e"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.0",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.41.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true,
    "reporters": [
      "default",
      "jest-html-reporter"
    ],
    "defaultTimeout": 30000
  }
}
